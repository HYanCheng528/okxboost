# ============================================================
# Data source: explorer or rpc.
# ============================================================
TX_SOURCE=explorer

# ============================================================
# BSC (BNB Smart Chain). Comma-separated RPC URLs are supported.
# ============================================================
BSC_RPC_URL=https://rpc.ankr.com/bsc/YOUR_ANKR_API_KEY,https://bsc-dataseed.bnbchain.org
# Optional WSS RPC for fast copy-sell balance polling. HTTP RPC is still used for quote/trade.
BSC_WSS_RPC_URL=wss://your-bsc-wss-rpc
BSC_EXPLORER_API_URL=
BSC_EXPLORER_API_KEY=YOUR_BSCSCAN_API_KEY

# ============================================================
# Base
# ============================================================
BASE_RPC_URL=https://rpc.ankr.com/base/YOUR_ANKR_API_KEY
BASE_WSS_RPC_URL=
BASE_EXPLORER_API_URL=
BASE_EXPLORER_API_KEY=

# ============================================================
# Arbitrum
# ============================================================
ARBITRUM_RPC_URL=https://rpc.ankr.com/arbitrum/YOUR_ANKR_API_KEY
ARBITRUM_WSS_RPC_URL=
ARBITRUM_EXPLORER_API_URL=
ARBITRUM_EXPLORER_API_KEY=

# ============================================================
# Ethereum
# ============================================================
ETHEREUM_RPC_URL=https://rpc.ankr.com/eth/YOUR_ANKR_API_KEY
ETHEREUM_WSS_RPC_URL=
ETHEREUM_EXPLORER_API_URL=
ETHEREUM_EXPLORER_API_KEY=

# ============================================================
# X Layer (OKX L2)
# ============================================================
XLAYER_RPC_URL=https://xlayer.drpc.org,https://rpc.xlayer.tech,https://xlayerrpc.okx.com
XLAYER_WSS_RPC_URL=
XLAYER_EXPLORER_API_URL=
XLAYER_EXPLORER_API_KEY=

# ============================================================
# Solana
# ============================================================
# Solana RPC is configured separately because it is not EVM JSON-RPC.
# Use mainnet for real airdrops; devnet has different mints and wallets.
SOLANA_RPC_URL=https://solana-rpc.publicnode.com,https://api.mainnet-beta.solana.com
# Optional extra stable mints for Solana sell detection, format SYMBOL:MINT,SYMBOL:MINT.
# Defaults include Solana mainnet USDC and Circle devnet USDC.
SOLANA_STABLE_MINTS=

# ============================================================
# Feishu Bitable sync (optional)
# ============================================================
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_APP_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Feishu bot webhook / PushPlus (optional)
# ============================================================
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PUSHPLUS_TOKEN=your_pushplus_token_here

# One-click detection session splitting.
DETECT_SESSION_GAP_MINUTES=30
DETECT_SESSION_PADDING_SECONDS=60
DETECT_SCAN_MAX_WORKERS=2

# Airdrop scan wallet concurrency. Keep low to avoid RPC rate limits.
REWARD_SCAN_MAX_WORKERS=2

# Default dashboard/reminder low-watermark: next volume date is the first day
# whose rolling 10-day daily average falls below this value. Frontend can override it.
BOOST_MIN_DAILY_AVERAGE=0

# ============================================================
# Robot copy-sell trading (local/off by default)
# ============================================================
# Keep false unless you are intentionally testing local robot-wallet selling.
ROBOT_TRADING_ENABLED=false
# Encrypted JSON keystore generated by scripts/import_robot_keystore.py.
ROBOT_KEYSTORE_PATH=data/robot_wallets.enc.json
# Password used to decrypt the keystore. Do not commit real values.
ROBOT_KEYSTORE_PASSWORD=
