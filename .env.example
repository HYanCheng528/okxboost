# ============================================================
# 数据来源：explorer（推荐）或 rpc
# ============================================================
TX_SOURCE=explorer

# ============================================================
# BSC（BNB Smart Chain）
# RPC_URL 支持逗号分隔多个节点，自动 fallback
# ============================================================
BSC_RPC_URL=https://rpc.ankr.com/bsc/YOUR_ANKR_API_KEY,https://bsc-dataseed.bnbchain.org
BSC_EXPLORER_API_URL=
BSC_EXPLORER_API_KEY=YOUR_BSCSCAN_API_KEY

# ============================================================
# Base
# ============================================================
BASE_RPC_URL=https://rpc.ankr.com/base/YOUR_ANKR_API_KEY
BASE_EXPLORER_API_URL=
BASE_EXPLORER_API_KEY=

# ============================================================
# Arbitrum
# ============================================================
ARBITRUM_RPC_URL=https://rpc.ankr.com/arbitrum/YOUR_ANKR_API_KEY
ARBITRUM_EXPLORER_API_URL=
ARBITRUM_EXPLORER_API_KEY=

# ============================================================
# Ethereum
# ============================================================
ETHEREUM_RPC_URL=https://rpc.ankr.com/eth/YOUR_ANKR_API_KEY
ETHEREUM_EXPLORER_API_URL=
ETHEREUM_EXPLORER_API_KEY=

# ============================================================
# 飞书多维表格（可选，不填则飞书同步功能不可用）
# 在飞书开放平台创建企业自建应用后获取
# ============================================================
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_APP_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
